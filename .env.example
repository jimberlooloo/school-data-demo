# Copy to .env (gitignored) and `source` it, or export these before running ingest scripts.
# These are NOT secrets: the account locator is public, and auth is via the local
# private key file (which never leaves your machine and is not in this repo).
# Snowflake account locator (org-account, e.g. ab12345-xy67890) — only for the live-Snowflake
# backend (local dev). Leave blank to use the bundled DuckDB.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_PRIVATE_KEY_PATH=~/.snowflake/rsa_key.p8

# AI layer (optional). Groq has a genuinely free tier (no card) and works in the UK.
AI_PROVIDER=groq
GROQ_API_KEY=
# GEMINI_API_KEY=     # note: Gemini free tier can be 0-quota in some regions (e.g. UK)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# AI_MODEL=llama-3.3-70b-versatile   # (groq default; or gemini-2.0-flash, gpt-4o-mini, etc.)
# Run AI queries under a read-only role (after running snowflake/setup_reader.sql):
# SNOWFLAKE_AI_ROLE=READER
